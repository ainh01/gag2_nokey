-- DANH SÁCH VẬT PHẨM HỖ TRỢ (ĐÃ THÊM BAMBOO)
local supportedItems = {
    ["Speed Mushroom"] = "Mushrooms", ["Jump Mushroom"] = "Mushrooms",
    ["Supersize Mushroom"] = "Mushrooms", ["Shrink Mushroom"] = "Mushrooms",
    ["Invisibility Mushroom"] = "Mushrooms", 
    ["Gold"] = "Seeds", 
    ["Rainbow"] = "Seeds",
    ["Bamboo"] = "Seeds" -- <== CẬP NHẬT TẠI ĐÂY
}

local function formatLV(str) return "\v" .. string.char(#str) .. str end

local function sendBatch(items)
    local n = #items
    local headerByteValue = 14 + (n * 6)
    local header = "\249\000" .. string.char(headerByteValue) .. "\000\000" .. friendBytes
    local payload = ""
    for i, data in ipairs(items) do
        local indexMarker = (i == 1) and ("\028\005" .. string.char(i) .. "\028") or ("\005" .. string.char(i) .. "\028")
        payload = payload .. indexMarker .. "\v\aItemKey" .. formatLV(data.name) .. "\v\005Count\005" .. string.char(data.count) .. "\v\bCategory" .. formatLV(data.cat) .. "\000"
    end
    remote:FireServer(buffer.fromstring(header .. payload .. "\000\000"))
end

local function runAutoTrade()
    if isSending or not isAutoEnabled then return end
    isSending = true
    
    local allItems = {}
    for _, item in ipairs(backpack:GetChildren()) do
        local category = supportedItems[item.Name]
        if category then
            table.insert(allItems, {name = item.Name, cat = category, count = item:GetAttribute("Count") or 1})
        end
    end

    if #allItems > 0 then
        local batchSize = 30
        for i = 1, #allItems, batchSize do
            if not isAutoEnabled or not isScriptRunning then break end
            local batch = {}
            for j = i, math.min(i + batchSize - 1, #allItems) do table.insert(batch, allItems[j]) end
            sendBatch(batch)
            if i + batchSize <= #allItems then task.wait(11) end
        end
    end
    isSending = false
end

